# Copy this file to docker/.env and fill in real values before `docker compose up -d`.
# n8n reads these via docker-compose's `env_file`, so they become available to workflow
# expressions as $env.VAR_NAME.

# --- NocoDB -----------------------------------------------------------------
# Base URL n8n uses to reach NocoDB. Inside the docker-compose network the
# service name "nocodb" resolves directly; from the host it's localhost:8080.
NOCODB_BASE_URL=http://nocodb:8080

# Table IDs (NOT table names) as shown in NocoDB's API docs page for each
# table (Base > ... > API Docs), e.g. "mAbCdEfGhIjKlMn". Filled in automatically
# if you run scripts/setup-nocodb.js (it prints them at the end).
NOCODB_TABLE_INVOICES=
NOCODB_TABLE_DEPARTMENTS=
NOCODB_TABLE_VENDORS=
NOCODB_TABLE_AUDITLOG=

# --- OpenAI -------------------------------------------------------------------
OPENAI_MODEL=gpt-4o-2024-08-06

# --- Approval routing ---------------------------------------------------------
# Public base URL approvers' Slack/email links point back to. For local testing
# this is n8n's own address; for a real demo across the internet use an ngrok/
# cloudflared tunnel URL instead so Slack/email clients can reach it.
APPROVAL_WEBHOOK_BASE_URL=http://localhost:5678

# Confidence threshold below which a Draft invoice is auto-flagged ReviewRequired=true
CONFIDENCE_REVIEW_THRESHOLD=0.75

# Slack channel ID used by the error-handler workflow for failure alerts
SLACK_ALERT_CHANNEL=

# --- Email (SMTP) fallback for approval requests ------------------------------
SMTP_FROM_ADDRESS=invoices@example.com
